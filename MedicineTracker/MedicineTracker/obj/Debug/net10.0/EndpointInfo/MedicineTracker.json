        "tags": [
          "Medicines"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Medicines"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Medicine"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Medicine"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Medicine"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Sales": {
      "get": {
        "tags": [
          "Sales"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Sales"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaleRecord"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SaleRecord"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SaleRecord"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
